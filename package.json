{
	"name": "@andrevlopes/blip-api-client",
	"version": "1.0.12",
	"description": "Blip API Client for javascript",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"build"
	],
	"engines": {
		"node": ">=22"
	},
	"types": "./build/index.d.ts",
	"exports": {
		".": {
			"types": "./build/index.d.ts",
			"import": "./build/index.js",
			"require": "./build/index.js"
		}
	},
	"scripts": {
		"prepublishOnly": "npm run build",
		"typecheck": "tsc --noEmit",
		"package": "tsc -p tsconfig.build.json & pnpm pack",
		"doc": "typedoc",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run --coverage",
		"dev": "tsx src/index.ts",
		"deploy:docs": "aws s3 sync docs/ s3://blip-api-client-docs --exclude \"*.html\" --cache-control \"public, max-age=31536000, immutable\" --delete && aws s3 sync docs/ s3://blip-api-client-docs --exclude \"*\" --include \"*.html\" --cache-control \"no-cache\" && aws cloudfront create-invalidation --distribution-id E1TZZJ823NNEQI --paths \"/*\""
	},
	"keywords": [
		"blip",
		"skeps",
		"api-client"
	],
	"author": "Andre V Lopes <andrellopes021@gmail.com> (https://github.com/Andrevlopess)",
	"license": "ISC",
	"homepage": "https://github.com/Andrevlopess/blip-api-client",
	"bugs": {
		"url": "https://github.com/Andrevlopess/blip-api-client/issues"
	},
	"packageManager": "pnpm@10.18.3",
	"dependencies": {
		"axios": "^1.17.0",
		"p-limit": "^7.3.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^25.9.3",
		"@vitest/coverage-v8": "4.1.9",
		"tsx": "^4.22.4",
		"typedoc": "^0.28.19",
		"typedoc-github-theme": "^0.4.0",
		"vitest": "^4.1.9"
	}
}
